{
  "name": "rijksmuseum-iconclass-mcp",
  "version": "0.4.0",
  "description": "MCP server for Iconclass — a hierarchical art-subject classification system (1.3M notations, 13 languages, semantic search)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && (git rev-parse --short HEAD > dist/commit.txt 2>/dev/null || true)",
    "build:skill": "bash scripts/build-skill.sh",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "serve": "node dist/index.js --http",
    "lint": "eslint src/",
    "test": "node scripts/tests/test-pure-functions.mjs && node scripts/tests/test-units.mjs",
    "test:tools": "node scripts/tests/test-tools.mjs",
    "test:http": "node scripts/tests/test-http-concurrency.mjs",
    "test:all": "node scripts/tests/test-pure-functions.mjs && node scripts/tests/test-tools.mjs && node scripts/tests/test-http-concurrency.mjs",
    "warm-cache": "node scripts/warm-cache-local.mjs --validate"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "sqlite-vec": "0.1.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.0"
  }
}
